<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recuerdos</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,sans-serif;background:#fafafa}
header{position:sticky;top:0;background:#fff;padding:15px;text-align:center;border-bottom:1px solid #ddd;z-index:1000}
h1{color:#e1306c}
#galeria{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:15px;padding:20px}
.card{background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.card img,.card video{width:100%;height:300px;object-fit:cover;display:block}
.loading{text-align:center;padding:40px}
.modal{display:none;position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.95);justify-content:center;align-items:center;z-index:9999}
.modal img,.modal video{max-width:95%;max-height:95%}
.cerrar{position:absolute;top:20px;right:30px;color:white;font-size:40px;cursor:pointer}
</style>
</head>
<body>
<header><h1>📸 Mis Recuerdos</h1></header>
<div class="loading" id="loading">Cargando recuerdos...</div>
<div id="galeria"></div>
<div class="modal" id="modal"><span class="cerrar">&times;</span></div>

<script>
const galeria=document.getElementById("galeria");
const modal=document.getElementById("modal");
const loading=document.getElementById("loading");

fetch("media.json")
.then(r=>{if(!r.ok) throw new Error("No se encontró media.json"); return r.json();})
.then(archivos=>{
 loading.style.display="none";
 archivos.forEach(ruta=>{
   const card=document.createElement("div");
   card.className="card";

   if(ruta.toLowerCase().endsWith(".mp4")){
      const video=document.createElement("video");
      video.src=ruta;
      video.controls=true;
      video.preload="none";
      card.appendChild(video);
   }else{
      const img=document.createElement("img");
      img.src=ruta;
      img.loading="lazy";
      img.onclick=()=>{
        modal.innerHTML=`<span class="cerrar">&times;</span><img src="${ruta}">`;
        modal.style.display="flex";
        modal.querySelector(".cerrar").onclick=()=>modal.style.display="none";
      };
      card.appendChild(img);
   }
   galeria.appendChild(card);
 });
})
.catch(e=>{
 loading.innerHTML="❌ No se pudieron cargar los recuerdos.<br>"+e.message;
});

modal.onclick=(e)=>{
 if(e.target===modal) modal.style.display="none";
};
</script>
</body>
</html>
